# ── Convex ────────────────────────────────────────────
# Run `npx convex dev` and it'll populate CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL
# Also available from your Convex dashboard at https://dashboard.convex.dev
CONVEX_DEPLOYMENT=dev:your-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── Clerk Authentication & Billing ────────────────────
# Get these from your Clerk dashboard at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
# Note: CLERK_WEBHOOK_SECRET should be set in your Convex dashboard environment variables
# Do not add it to this .env.local file

# ── Clerk Frontend API URL ─────────────────────────────
# Found in your JWT template in Clerk dashboard (template named "convex")
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://your-clerk-frontend-api-url.clerk.accounts.dev

# ── Clerk Route URLs ───────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Clerk Redirect URLs ────────────────────────────────
# After sign-in/sign-up, route through org-selection then fall back to dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/org-selection
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/org-selection
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── AI Providers ───────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Direct Stripe (only if migrating from Clerk Billing) ──
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Trigger.dev (optional add-on) ─────────────────────
# TRIGGER_SECRET_KEY=tr_dev_...

# ── Composio (optional add-on) ────────────────────────
# COMPOSIO_API_KEY=...
